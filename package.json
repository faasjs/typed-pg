{
  "name": "typed-pg-mono",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "test": "vp test run",
    "ci": "vp test run --silent --coverage",
    "build": "vp pack",
    "check": "vp check",
    "clean": "rm -rf packages/*/node_modules packages/*/dist coverage tmp *.log test-report.junit.xml",
    "prepare": "vp config"
  },
  "devDependencies": {
    "vite-plus": "*"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core",
    "vitest": "npm:@voidzero-dev/vite-plus-test"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.11.0"
}
